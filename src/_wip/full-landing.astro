---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PluginCard from '../components/PluginCard.astro';
import HeroGlow from '../components/HeroGlow.astro';
import { plugins } from '../data/plugins';

const paidCount = plugins.filter((p) => p.price !== null).length;

const faqs = [
  {
    q: 'If the plugins are open source, why pay?',
    a: 'Every Camden plugin is GPL-3.0 — the full source is on GitHub and you can build it yourself for free. Buying gets you signed, ready-to-install binaries for every format, saves you a toolchain and a long compile, and directly funds continued development.',
  },
  {
    q: 'Which formats do I get?',
    a: 'Paid builds ship as VST3, CLAP and Standalone on Windows, macOS and Linux, plus AU on macOS and LV2 on Linux. One purchase covers every format and platform.',
  },
  {
    q: 'How does licensing work?',
    a: 'Checkout is handled by Lemon Squeezy (our merchant of record — they take care of VAT/sales tax worldwide). You receive a license key and secure download links by email right after purchase.',
  },
  {
    q: 'Is there a trial?',
    a: 'Since the source is open, the honest "trial" is to build it yourself. A time-limited demo build is on the roadmap.',
  },
];
---

<Layout>
  <div class="font-display">
  <Nav />

  <main>
    <!-- ============================ HERO ============================ -->
    <section class="relative overflow-hidden">
      <HeroGlow />

      <!-- hero knob mark (the full glowing CamdenLookAndFeel knob) -->
      <img
        src="/camden-logo.svg"
        alt="Camden Plugins"
        width="360"
        height="360"
        class="pointer-events-none absolute right-4 top-24 hidden w-64 opacity-90 drop-shadow-2xl lg:block xl:w-80"
      />

      <div class="relative mx-auto max-w-6xl px-6 pb-24 pt-20 md:pt-28">
        <p
          class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium tracking-wide text-white/70"
        >
          <span class="h-2 w-2 rounded-full bg-green"></span>
          {plugins.length} plugins · open source · one shared engine
        </p>

        <h1
          class="max-w-3xl text-4xl font-semibold leading-[1.05] tracking-tight md:text-6xl"
        >
          Audio plugins.<br />
          <span class="text-amber">Made in London.</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/65">
          Saturation, clipping and dynamics — hand-built on a shared C++/JUCE
          core. Buy the signed binaries, or clone the repo and build them
          yourself. Both are first-class.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a
            href="#plugins"
            class="rounded-md bg-amber px-6 py-3 font-semibold text-[#181d2e] transition-opacity hover:opacity-90"
          >
            Browse the plugins
          </a>
          <a
            href="https://github.com/camden-plugins"
            target="_blank"
            rel="noopener"
            class="rounded-md border border-white/15 px-6 py-3 font-semibold text-white/80 transition-colors hover:border-white/30 hover:text-white"
          >
            View source on GitHub
          </a>
        </div>

        <!-- accent bar -->
        <div class="mt-16 h-1.5 w-40 rounded-full bg-amber"></div>
      </div>
    </section>

    <!-- ========================== PLUGINS =========================== -->
    <section id="plugins" class="mx-auto max-w-6xl scroll-mt-20 px-6 py-20">
      <div class="mb-10 flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div>
          <h2 class="text-3xl font-semibold tracking-tight">The line-up</h2>
          <p class="mt-2 max-w-lg text-white/60">
            {paidCount} plugins available now, each with its own character —
            and its own repository.
          </p>
        </div>
        <a
          href="https://github.com/camden-plugins"
          target="_blank"
          rel="noopener"
          class="text-sm font-semibold text-white/60 transition-colors hover:text-white"
        >
          All repositories →
        </a>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        {plugins.map((plugin) => <PluginCard plugin={plugin} />)}
      </div>
    </section>

    <!-- ======================= OPEN SOURCE ========================== -->
    <section
      id="open-source"
      class="scroll-mt-20 border-y border-white/10 bg-white/[0.02]"
    >
      <div class="mx-auto max-w-6xl px-6 py-20">
        <h2 class="max-w-2xl text-3xl font-semibold tracking-tight">
          Open source <span class="text-white/40">and</span> for sale — no catch.
        </h2>
        <div class="mt-10 grid gap-8 md:grid-cols-3">
          <div class="panel p-6">
            <h3 class="text-lg font-semibold text-amber">Build it free</h3>
            <p class="mt-3 text-sm leading-relaxed text-white/65">
              Every plugin is GPL-3.0. Clone the repo, run CMake, and you have
              the exact same plugin — nothing is held back.
            </p>
          </div>
          <div class="panel p-6">
            <h3 class="text-lg font-semibold text-green">Or buy the binary</h3>
            <p class="mt-3 text-sm leading-relaxed text-white/65">
              Skip the toolchain and the compile. Get signed installers for
              every format and platform, ready to drop into your DAW.
            </p>
          </div>
          <div class="panel p-6">
            <h3 class="text-lg font-semibold text-blue">Fund the work</h3>
            <p class="mt-3 text-sm leading-relaxed text-white/65">
              Purchases pay for the next plugin, the next feature and the next
              bug fix. It's the most direct way to support the project.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================ FAQ ============================= -->
    <section id="faq" class="mx-auto max-w-3xl scroll-mt-20 px-6 py-20">
      <h2 class="text-3xl font-semibold tracking-tight">Questions</h2>
      <div class="mt-8 divide-y divide-white/10">
        {
          faqs.map((f) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-medium text-white/90">
                {f.q}
                <span class="text-amber transition-transform group-open:rotate-45">
                  +
                </span>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-white/60">{f.a}</p>
            </details>
          ))
        }
      </div>
    </section>

    <!-- =========================== CTA ============================== -->
    <section class="px-6 pb-24">
      <div
        class="relative mx-auto max-w-6xl overflow-hidden rounded-2xl border border-amber/20 bg-gradient-to-br from-amber/10 to-transparent px-8 py-16 text-center"
      >
        <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">
          Ready to plug in?
        </h2>
        <p class="mx-auto mt-4 max-w-md text-white/65">
          Pick a plugin, grab the binary, and get back to mixing.
        </p>
        <a
          href="#plugins"
          class="mt-8 inline-block rounded-md bg-amber px-7 py-3 font-semibold text-[#181d2e] transition-opacity hover:opacity-90"
        >
          Browse the plugins
        </a>
      </div>
    </section>
  </main>

  <Footer />
  </div>
</Layout>
