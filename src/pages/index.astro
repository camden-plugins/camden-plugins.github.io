---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
---

<Layout>
  <main
    class="relative flex min-h-screen flex-col items-center justify-center px-6 text-center"
  >
    <!-- soft amber glow as a GPU-dithered radial gradient (no banding),
         sitting behind the grunge paint texture -->
    <div
      class="pointer-events-none absolute inset-0 -z-10"
      style="background: radial-gradient(ellipse 48% 38% at 50% 42%, rgba(255,170,0,0.16), rgba(255,170,0,0.05) 45%, rgba(255,170,0,0) 72%);"
    >
    </div>

    <!-- fractal-noise dither over the glow to kill any residual gradient banding -->
    <div
      class="dither pointer-events-none absolute inset-0 -z-10 opacity-20"
    >
    </div>

    <div class="relative flex flex-col items-center">
      <Logo class="h-20 w-20" />

      <h1
        class="mt-8 font-display text-4xl font-semibold uppercase tracking-[0.15em] md:text-5xl"
      >
        Camden
      </h1>

      <p class="mt-4 max-w-md text-white/55">
        Audio plugins. Made in London.
      </p>

      <!-- accent bar -->
      <div class="mt-10 h-1.5 w-56 rounded-full bg-amber"></div>

      <p class="mt-10 text-xs uppercase tracking-[0.3em] text-white/35">
        Coming soon
      </p>
    </div>
  </main>
</Layout>
