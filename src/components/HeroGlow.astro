---
// Shared hero amber glow — a Gaussian-approximating radial gradient (stops along
// exp(-x²/2σ²)) so the tail rolls off gently with no hard "ball" edge. The
// gradient is GPU-dithered and a fractal-noise layer sits below it, so there is
// no visible banding on the dark background. Meant to live inside a
// `position: relative` container; it fills it and sits behind the content.
---

<div
  class="pointer-events-none absolute inset-0 -z-10"
  style="background: radial-gradient(circle 62vh at 50% 52%, rgba(255,170,0,0.16) 0%, rgba(255,170,0,0.154) 8%, rgba(255,170,0,0.137) 17%, rgba(255,170,0,0.113) 25%, rgba(255,170,0,0.086) 33%, rgba(255,170,0,0.061) 42%, rgba(255,170,0,0.040) 50%, rgba(255,170,0,0.024) 58%, rgba(255,170,0,0.0135) 67%, rgba(255,170,0,0.0070) 75%, rgba(255,170,0,0.0034) 83%, rgba(255,170,0,0.0015) 92%, rgba(255,170,0,0) 100%);"
>
</div>

<div class="dither pointer-events-none absolute inset-0 -z-10 opacity-20"></div>
