---
// The London Underground "roundel" mark, recoloured to the brand accent.
interface Props {
  class?: string;
  color?: string;
}
const { class: className = '', color = 'var(--color-amber)' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 100 100"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Camden Plugins roundel"
>
  <circle cx="50" cy="50" r="34" stroke={color} stroke-width="10" fill="none" />
  <rect x="6" y="43" width="88" height="14" rx="2" fill={color} />
</svg>
