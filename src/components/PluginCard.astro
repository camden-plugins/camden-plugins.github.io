---
import type { Plugin } from '../data/plugins';

interface Props {
  plugin: Plugin;
}
const { plugin } = Astro.props;

const accentHex: Record<Plugin['accent'], string> = {
  amber: '#ffaa00',
  red: '#e94560',
  blue: '#3e92f4',
  green: '#95c17c',
};
const accent = accentHex[plugin.accent];
---

<article
  class="panel group relative flex flex-col overflow-hidden p-6 transition-transform duration-200 hover:-translate-y-1"
  style={`--accent: ${accent};`}
>
  {
    plugin.flagship && (
      <span class="absolute right-4 top-4 rounded-full border border-[var(--accent)]/40 bg-[var(--accent)]/10 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wider text-[var(--accent)]">
        Flagship
      </span>
    )
  }

  <!-- accent bar, like a tube line -->
  <div class="mb-5 h-1 w-12 rounded-full" style={`background:${accent}`}></div>

  <span class="text-xs font-semibold uppercase tracking-[0.2em] text-white/40">
    {plugin.category}
  </span>
  <h3 class="mt-1 text-2xl font-semibold text-white">{plugin.name}</h3>
  <p class="mt-0.5 text-sm text-[var(--accent)]">{plugin.tagline}</p>

  <p class="mt-4 flex-1 font-text text-sm leading-relaxed text-white/65">{plugin.blurb}</p>

  <ul class="mt-5 flex flex-wrap gap-1.5">
    {
      plugin.formats.map((f) => (
        <li class="rounded border border-white/10 bg-white/5 px-2 py-0.5 text-[11px] text-white/55">
          {f}
        </li>
      ))
    }
  </ul>

  <div class="mt-6 flex items-center justify-between gap-3 border-t border-white/10 pt-5">
    <div>
      {
        plugin.price !== null ? (
          <p class="text-2xl font-semibold text-white">
            ${plugin.price}
            <span class="ml-1 text-xs font-normal text-white/40">USD</span>
          </p>
        ) : (
          <p class="text-lg font-semibold text-white">Free</p>
        )
      }
    </div>

    <div class="flex items-center gap-2">
      <a
        href={plugin.repoUrl}
        target="_blank"
        rel="noopener"
        class="rounded-md border border-white/15 px-3 py-2 text-xs font-semibold text-white/70 transition-colors hover:border-white/30 hover:text-white"
      >
        Source
      </a>
      <a
        href={plugin.buyUrl ?? '#'}
        data-buy={plugin.buyUrl ? 'ready' : 'pending'}
        class="rounded-md px-4 py-2 text-xs font-semibold text-[#1b1e29] transition-opacity hover:opacity-90"
        style={`background:${accent}`}
      >
        {plugin.buyUrl ? 'Buy' : 'Coming soon'}
      </a>
    </div>
  </div>
</article>
