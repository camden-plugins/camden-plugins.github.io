---
import Logo from './Logo.astro';

const links = [
  { label: 'Plugins', href: '#plugins' },
  { label: 'Why open source', href: '#open-source' },
  { label: 'FAQ', href: '#faq' },
];
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-[#181d2e]/80 backdrop-blur-md"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3 group">
      <Logo class="h-8 w-8 transition-transform group-hover:scale-105" />
      <span class="font-display text-lg font-semibold tracking-wide">Camden Plugins</span>
    </a>

    <ul class="hidden items-center gap-8 text-sm text-white/70 md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="transition-colors hover:text-white"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="#plugins"
      class="rounded-md border border-amber/40 bg-amber/10 px-4 py-2 text-sm font-semibold text-amber transition-colors hover:bg-amber/20"
    >
      Get the plugins
    </a>
  </nav>
</header>
